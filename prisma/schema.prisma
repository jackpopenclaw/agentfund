generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password_hash  String
  name           String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  profiles AgentFundProfile[]
}

model AgentFundProfile {
  id                String   @id @default(uuid())
  user_id           String   @unique
  agent_id          String   @unique
  stripe_connect_id String?
  display_name      String
  description       String?
  avatar_url        String?
  total_received    Int      @default(0)
  current_balance   Int      @default(0)
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  milestones   Milestone[]
  donations    Donation[]
  subscriptions Subscription[]
  payouts      Payout[]

  @@index([agent_id])
  @@index([user_id])
}

model Milestone {
  id              String            @id @default(uuid())
  agent_fund_id   String
  title           String
  description     String?
  target_amount   Int
  current_amount  Int               @default(0)
  status          String            @default("active")
  display_order   Int               @default(0)
  completed_at    DateTime?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  agent_fund AgentFundProfile @relation(fields: [agent_fund_id], references: [id], onDelete: Cascade)

  @@index([agent_fund_id])
  @@index([status])
}

model Donation {
  id                      String          @id @default(uuid())
  agent_fund_id           String
  donor_id                String?
  stripe_payment_intent_id String         @unique
  stripe_charge_id        String?
  amount                  Int
  type                    String          @default("one_time")
  is_anonymous            Boolean         @default(false)
  donor_name              String?
  message                 String?
  status                  String          @default("pending")
  created_at              DateTime        @default(now())
  updated_at              DateTime        @updatedAt

  agent_fund AgentFundProfile @relation(fields: [agent_fund_id], references: [id], onDelete: Cascade)

  @@index([agent_fund_id])
  @@index([donor_id])
  @@index([status])
  @@index([created_at])
}

model Subscription {
  id                      String                @id @default(uuid())
  agent_fund_id           String
  donor_id                String
  stripe_subscription_id  String                @unique
  stripe_customer_id      String
  amount                  Int
  status                  String                @default("active")
  is_anonymous            Boolean               @default(false)
  donor_name              String?
  current_period_start    DateTime
  current_period_end      DateTime
  cancelled_at            DateTime?
  created_at              DateTime              @default(now())
  updated_at              DateTime              @updatedAt

  agent_fund AgentFundProfile @relation(fields: [agent_fund_id], references: [id], onDelete: Cascade)

  @@index([agent_fund_id])
  @@index([donor_id])
  @@index([status])
}

model Payout {
  id                String        @id @default(uuid())
  agent_fund_id     String
  stripe_transfer_id String       @unique
  amount            Int
  status            String        @default("pending")
  created_at        DateTime      @default(now())
  completed_at      DateTime?

  agent_fund AgentFundProfile @relation(fields: [agent_fund_id], references: [id], onDelete: Cascade)

  @@index([agent_fund_id])
  @@index([status])
}
